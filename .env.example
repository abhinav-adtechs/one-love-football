# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — browser-safe Supabase credentials
NEXT_PUBLIC_ONE_LOVE_SUPABASE_URL=
NEXT_PUBLIC_ONE_LOVE_SUPABASE_PUBLISHABLE_KEY=

# Optional — server-side only (migrations, Edge Functions). Never expose in browser.
# ONE_LOVE_SUPABASE_SERVICE_ROLE_KEY=
# ONE_LOVE_SUPABASE_JWT_SECRET=
# ONE_LOVE_POSTGRES_URL=
# ONE_LOVE_POSTGRES_URL_NON_POOLING=
